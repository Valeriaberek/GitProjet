PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/rowing_logbook

# JWT Secrets (min 32 chars)
JWT_ACCESS_SECRET=your-access-token-secret-key-min-32-chars-required
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-chars-required
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=30d

# Email Service (Mailpit local)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=test@example.com
MAIL_PASS=
MAIL_FROM=noreply@rowing-logbook.local

# Frontend
FRONTEND_URL=http://localhost:5173
